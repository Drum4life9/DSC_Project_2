model1.fit <- lme(hearing.loss ~ (years + I(years^2)) * Noise.level,
random = ~ years | subject,
data = data,
weights = varIdent(form = ~ 1 | factor(years)),
method = "ML") # Use ML for LRT comparisons later
summary(m_max)
summary(model1.fit)
model1.fit <- lme(hearing.loss ~ (years + years_sq) * Noise.level + ,
model1.fit <- lme(hearing.loss ~ (years + years_sq) * Noise.level,
random = ~ years | subject,
data = data,
weights = varIdent(form = ~ 1 | factor(years)),
method = "ML") # Use ML for LRT comparisons later
summary(model1.fit)
model2.fit <- update(model1.fit, . ~ . - years_sq * Noise.level)
summary(model2.fit)
model2.fit <- update(model1.fit, . ~ . - years_sq * Noise.level)
model2.fit <- update(model2.fit, . ~ . + years_sq)
summary(model2.fit)
model2.fit <- update(model1.fit, . ~ . - years_sq * Noise.level)
model2.fit <- update(model2.fit, . ~ . + years_sq + Noise.level)
summary(model2.fit)
anova(model2.fit, model1.fit)
anova(model1.fit, model2.fit)
model2.fit <- lme(hearing.loss ~ years * Noise.level + I(years^2),
random = ~ years | subject,
data = data,
weights = varIdent(form = ~ 1 | factor(years)),
method = "ML")
# Compare to the maximal model using Likelihood Ratio Test (LRT)
anova(model1.fit, model2.fit)
model1.fit <- lme(hearing.loss ~ (years + years_sq) * Noise.level,
random = ~ years | subject,
data = data,
weights = varIdent(form = ~ 1 | factor(years)),
method = "ML") # Use ML for LRT comparisons later
summary(model1.fit)
model2.fit <- update(model1.fit, . ~ years * Noise.level + years_sq)
# Compare to the maximal model using Likelihood Ratio Test (LRT)
anova(model1.fit, model2.fit)
model2.fit <- update(model1.fit, . ~ years * Noise.level + years_sq)
# Compare to the maximal model using Likelihood Ratio Test (LRT)
anova(model1.fit, model2.fit)
# Extract residuals and calculate ACF
# We use 'normalized = TRUE' because of your varIdent weights
res_m2 <- residuals(model2.fit, type = "normalized")
# Plot the Autocorrelation
plot(ACF(model2.fit, resType = "normalized"),
alpha = 0.05,
main = "ACF of Normalized Residuals (Model 2)")
# Plot the Autocorrelation
plot(PACF(model2.fit, resType = "normalized"),
alpha = 0.05,
main = "ACF of Normalized Residuals (Model 2)")
pacf(res_m2, main = "Partial ACF of Residuals")
# Plot the Autocorrelation
plot(ACF(model2.fit, resType = "normalized"),
alpha = 0.05,
main = "ACF of Normalized Residuals (Model 2)")
# Plot the Autocorrelation
plot(ACF(model2.fit, resType = "normalized"),
alpha = 0.05,
main = "ACF of Normalized Residuals (Model 2)",
correlation = corAR1())
pacf(res_m2, main = "Partial ACF of Residuals")
# Plot the Autocorrelation
plot(ACF(model2.fit, resType = "normalized"),
alpha = 0.05,
main = "ACF of Normalized Residuals (Model 2)",
correlation = corAR1())
model2.corr <- update(model2.fit,
correlation = corAR1(form = ~ years | subject))
model2.corr <- update(model2.fit,
correlation = corAR1(form = ~ years | subject))
