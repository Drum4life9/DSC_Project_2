print(describeBy(MathAchieve, group = list(MathAchieve$Sex, MathAchieve$Minority)))
bwplot(MathAch ~ Sex + Minority | Sex * Minority, data = MathAchieve)
analysis_2 = aov(MathAch ~ Sex + Minority, data = MathAchieve)
summary(analysis_2)
