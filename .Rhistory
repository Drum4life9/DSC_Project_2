get_top_6 <- function(df, group_name) {
df %>%
filter(Noise.level == group_name) %>%
# We use abs() to find the most "extreme" subjects,
# or remove abs() if you only want the highest positive offsets
arrange(desc(abs(intercept_offset))) %>%
head(6)
}
